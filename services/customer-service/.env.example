# Customer Service Configuration

# Database connection URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/customer_service

# Alternative: Service-specific database URL (takes precedence over DATABASE_URL)
# CUSTOMER_SERVICE_DATABASE_URL=postgresql://postgres:password@localhost:5432/customer_service

# Server bind address
BIND_ADDRESS=0.0.0.0:3001

# Alternative: Service-specific bind address (takes precedence over BIND_ADDRESS)
# CUSTOMER_SERVICE_BIND_ADDRESS=0.0.0.0:3001

# Log level (trace, debug, info, warn, error)
LOG_LEVEL=info

# Alternative: Service-specific log level (takes precedence over LOG_LEVEL)
# CUSTOMER_SERVICE_LOG_LEVEL=debug

# Test database URL (used for integration tests)
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/customer_service_test