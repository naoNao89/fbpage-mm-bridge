# Facebook Graph Service Configuration

# Server
BIND_ADDRESS=0.0.0.0:3003
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/facebook_graph

# Facebook API Configuration
FACEBOOK_PAGE_ID=982057698331908
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token_here

# Customer Service (for creating/getting customers)
CUSTOMER_SERVICE_URL=http://localhost:3001

# Message Service (for storing messages)
MESSAGE_SERVICE_URL=http://localhost:3002

# Optional: Rate limiting
# RATE_LIMIT_WARNING_THRESHOLD=80.0
# RATE_LIMIT_CRITICAL_THRESHOLD=95.0
