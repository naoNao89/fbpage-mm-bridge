# Message Service Environment Variables

# Database connection URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/message_service

# Alternative database URL variable
MESSAGE_SERVICE_DATABASE_URL=postgresql://postgres:password@localhost:5432/message_service

# Server bind address
BIND_ADDRESS=0.0.0.0:3002

# Alternative bind address variable
MESSAGE_SERVICE_BIND_ADDRESS=0.0.0.0:3002

# Log level
LOG_LEVEL=info

# Alternative log level variable
MESSAGE_SERVICE_LOG_LEVEL=info

# Customer Service URL for validating customers
CUSTOMER_SERVICE_URL=http://localhost:3001
