# ==============================================================================
# Stage 1: Build test binaries in release mode (stripped symbols)
# ==============================================================================
FROM rust:slim-bookworm AS builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y \
    libssl-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Copy source
COPY . .

# Build tests in RELEASE mode (smaller binaries with stripped debug info)
RUN cargo build --release --workspace

# Compile tests
RUN cargo test --release --workspace --no-run

# ==============================================================================
# Stage 2: Minimal runtime
# ==============================================================================
FROM debian:bookworm-slim

WORKDIR /app

# Runtime dependencies only
RUN apt-get update && apt-get install -y \
    curl \
    gcc \
    pkg-config \
    postgresql-client \
    libssl3 \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy full target directory for incremental compilation
COPY --from=builder /app/target /app/target

# Copy source for test structure
COPY --from=builder /app/services /app/services
COPY --from=builder /app/src /app/src
COPY --from=builder /app/Cargo.toml /app/
COPY --from=builder /app/Cargo.lock /app/

ENV PATH="/root/.cargo/bin:$PATH"
ENV RUST_BACKTRACE=1
ENV TEST_LOG_LEVEL=debug

CMD ["cargo", "test", "--release", "--workspace", "--offline", "--", "--test-threads=1"]
