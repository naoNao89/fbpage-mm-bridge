# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fbpage_bridge
DATABASE_MAX_CONNECTIONS=5

# Mattermost Configuration
MATTERMOST_WEBHOOK_URL=https://your-mattermost-instance.com/hooks/your-webhook-id

# Facebook Configuration
FACEBOOK_VERIFY_TOKEN=your-verify-token-here
FACEBOOK_ACCESS_TOKEN=your-page-access-token-here

# Facebook Graph Service (for importing messages from Page)
# See docs/FACEBOOK_LONG_LIVED_TOKEN.md for setup instructions
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# SSH Configuration (for deployment - set as GitHub Secrets, not in .env)
# SSH_HOST=your.server.ip
# SSH_USERNAME=root
# DEPLOY_PATH=/opt/fbpage-mm-bridge
